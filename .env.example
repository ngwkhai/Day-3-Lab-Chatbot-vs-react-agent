# OPENAI SETTINGS (also works with any OpenAI-compatible endpoint)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: set this to use a custom OpenAI-compatible endpoint (leave blank for official OpenAI)
OPENAI_BASE_URL=

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# LAB CONFIG
# Options: openai | google | local
DEFAULT_PROVIDER=openai

# DEFAULT_MODEL applies to the OpenAI provider (it is IGNORED by Gemini unless it
# starts with "gemini"). Model names are NOT interchangeable across providers.
DEFAULT_MODEL=gpt-4o

# Optional per-provider overrides (take priority over DEFAULT_MODEL):
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash   # e.g. gemini-2.0-flash, gemini-1.5-flash

LOG_LEVEL=INFO
